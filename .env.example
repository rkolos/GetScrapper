# Пример файла переменных окружения для универсального рендерера
# Скопируйте этот файл в .env и заполните реальными значениями

# Browserbase настройки (обязательно для эскалации)
BROWSERBASE_API_KEY=your_browserbase_api_key_here
BROWSERBASE_PROJECT_ID=your_browserbase_project_id_here
BROWSERBASE_URL=https://api.browserbase.com

# Playwright настройки
PLAYWRIGHT_SERVER_URL=  # Опционально, для удаленного Playwright сервера
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT=30000
PLAYWRIGHT_REUSE_CONTEXT=false

# Детекция блокировок
DETECTION_CONFIDENCE_THRESHOLD=0.3
DETECTION_ENABLE_HTML_ANALYSIS=true

# Логирование
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(levelname)s - %(message)s

# Производительность
MAX_CONCURRENT_REQUESTS=10
REQUEST_TIMEOUT=30

# User-Agent (опционально)
USER_AGENT=Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36